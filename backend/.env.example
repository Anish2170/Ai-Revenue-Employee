# Production environment template for the Render backend service.
# Copy to `.env` for local testing, and add the same keys in Render > Environment.

# --- Runtime ---
NODE_ENV=production
PORT=10000
# Render supplies PORT automatically. HOST defaults to 0.0.0.0; set only if needed.
# HOST=0.0.0.0
# Optional build/version label shown by /health. Render can also supply RENDER_GIT_COMMIT.
# APP_VERSION=0.1.0

# --- Database (Postgres / Render Postgres / Neon) ---
# Use the internal Render database URL when backend and database are in the same Render account.
# Ensure sslmode=require when your provider requires TLS.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --- Google Gemini ---
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace-with-production-key
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# --- Auth / sessions ---
# Long random string used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_DAYS=30

# --- Public URLs ---
# Your deployed dashboard/frontend origin. Used for CORS and cookie-based auth.
FRONTEND_URL=https://your-dashboard.example.com
# Optional public landing page origin if it calls the backend directly.
LANDING_PAGE_URL=https://your-landing-page.example.com
# Dashboard origin. Usually the same as FRONTEND_URL.
DASHBOARD_ORIGIN=https://your-dashboard.example.com
# Public backend URL where widget.js is served. Used in generated widget snippets.
WIDGET_BASE_URL=https://your-backend.onrender.com

# --- CORS ---
# Production must be an explicit comma-separated allowlist. Do not use "*" in production.
# Include the dashboard, landing page, and any customer/widget origins that should call the API.
CORS_ORIGIN=https://your-dashboard.example.com,https://your-landing-page.example.com,https://customer-site.example.com

# --- Knowledge retrieval tuning ---
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.5
RETRIEVAL_MAX_CONTEXT_CHARS=9000
KNOWLEDGE_DIR=data/knowledge
KNOWLEDGE_SNAPSHOT_PATH=data/knowledge-index.json
MAX_CACHED_STORES=20

# --- Crawler limits ---
CRAWL_MAX_PAGES=25
CRAWL_CONCURRENCY=4
CRAWL_TIMEOUT_MS=12000
# Optional explicit Chrome/Edge executable for JS-rendered sites.
# CRAWL_BROWSER_PATH=/usr/bin/google-chrome-stable
# CHROME_PATH=/usr/bin/google-chrome-stable

# --- Debugging ---
# Keep false in production. Enables verbose prompt/RAG/popup traces when true.
DEBUG_TRACE=false
