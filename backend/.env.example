# Copy this file to `.env` and fill in your key.

# --- Google Gemini ---
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY= 
GEMINI_MODEL=gemini-2.5-flash

# --- RAG knowledge engine ---
EMBEDDING_MODEL=gemini-embedding-001
# RETRIEVAL_TOP_K=5
# RETRIEVAL_MIN_SCORE=0.5
# RETRIEVAL_MAX_CONTEXT_CHARS=9000
# CRAWL_MAX_PAGES=25
# CRAWL_CONCURRENCY=4
# CRAWL_TIMEOUT_MS=12000

# --- Database (Neon Postgres) ---
# Create a project at https://neon.tech, then paste the POOLED connection string here.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Auth ---
# Long random string used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=8787
NODE_ENV=development

# Comma-separated allowed origins for CORS. Widget embeds cross-origin (any), and the
# dashboard origin must be allowed WITH credentials for cookie auth.
CORS_ORIGIN=*
# The dashboard's origin (credentials allowed). Defaults to http://localhost:3001.
DASHBOARD_ORIGIN=http://localhost:3001
# Public base URL the widget script is served from (used in the generated snippet).
WIDGET_BASE_URL=http://localhost:8787

# Force-enable/disable the dev-only decision trace in the /engage response.
# Defaults to on when NODE_ENV !== production. Set to "false" to strip it everywhere.
# DEBUG_TRACE=true
